{
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-preset-recommend"
    },
    {
      "id": "@secretlint/secretlint-rule-pattern",
      "options": {
        "patterns": [
          {
            "name": "Local filesystem paths",
            "pattern": "/\\/Users\\/[\\w]+\\//",
            "message": "Found local filesystem path"
          },
          {
            "name": "Localhost URLs",
            "pattern": "/https?:\\/\\/(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0)/",
            "message": "Found localhost URL"
          },
          {
            "name": "link: or file: dependencies",
            "pattern": "/\"(link|file):/",
            "message": "Found link: or file: dependency"
          },
          {
            "name": "Unresolved workspace protocol",
            "pattern": "/\"workspace:[*^~]/",
            "message": "Found unresolved workspace: protocol"
          }
        ]
      }
    }
  ]
}
