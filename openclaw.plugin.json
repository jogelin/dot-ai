{
  "id": "dot-ai",
  "name": "dot-ai — Universal AI Workspace Convention",
  "description": "Workspace convention with model routing and context enforcement",
  "version": "0.10.1",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "workspace": {
        "type": "string",
        "description": "Absolute path to the project directory containing .ai/. Used when gateway/Discord/TUI cannot detect the workspace from cwd."
      },
      "modelRouting": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "defaultSubagentModel": {
            "type": "string",
            "default": "anthropic/claude-haiku"
          },
          "maxConcurrentSubagents": {
            "type": "number",
            "default": 8
          }
        }
      }
    }
  },
  "skills": [
    "skills/dot-ai",
    "skills/dot-ai-tasks",
    "skills/dot-ai-workspace-scan",
    "skills/dot-ai-project-init",
    "skills/dot-ai-audit",
    "skills/dot-ai-security",
    "skills/dot-ai-self-improve",
    "skills/dot-ai-agent-sync",
    "skills/dot-ai-skill-sync",
    "skills/dot-ai-backlog-sync",
    "skills/dot-ai-memory-sync",
    "skills/dot-ai-tools-sync",
    "skills/dot-ai-migrate",
    "skills/dot-ai-export",
    "skills/dot-ai-doctor",
    "skills/model-selection",
    "skills/context-strategy"
  ],
  "uiHints": {
    "workspace": {
      "label": "Workspace",
      "placeholder": "~/dev/my-project"
    },
    "modelRouting.enabled": {
      "label": "Enable Model Routing"
    },
    "modelRouting.defaultSubagentModel": {
      "label": "Default Sub-agent Model"
    }
  }
}
